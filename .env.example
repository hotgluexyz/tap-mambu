# Mambu Configuration
# Copy this file to .env and fill in your actual values.
# Variable names follow the tap's setting keys; run `tap-mambu --about` for the
# authoritative list.

# Required: Access key used to authenticate against Mambu
TAP_MAMBU_ACCESS_KEY=your_access_key_here

# Optional: The earliest record date to sync (ISO-8601)
TAP_MAMBU_START_DATE=2023-01-01T00:00:00Z

# Optional: API base URL (defaults to https://mbuhotglue.sandbox.mambu.com/api)
TAP_MAMBU_API_URL=https://mbuhotglue.sandbox.mambu.com/api

# Optional: Page size for GL journal entries (limit query param, default 50)
TAP_MAMBU_PAGE_SIZE=50
